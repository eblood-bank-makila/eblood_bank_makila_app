
# API Configuration
# Local backend over the USB/adb reverse tunnel — works on the physical device AND the emulator,
# and survives Mac IP changes / WiFi AP-isolation. Requires the tunnel to be active:
#   adb reverse tcp:7874 tcp:7874     (re-run after a device reconnect/reboot or adb restart)
BASE_URL=http://192.168.30.111:7874
BASE_API_URL=http://192.168.30.111:7874/api/v1
# Alternatives (no adb reverse needed):
#   Mac LAN IP — only if device is on the SAME WiFi with no client/AP isolation:
#     BASE_URL=http://192.168.30.111:7874   BASE_API_URL=http://192.168.30.111:7874/api/v1
#   Android emulator host alias (emulator only):
#     BASE_URL=http://10.0.2.2:7874       BASE_API_URL=http://10.0.2.2:7874/api/v1
API_CONSUMER=gAAAAABqHwEF6KfBGY9_UQUewdiKhmxyNCOJQI3yk3nFaJDPey9HzH-kOkVOIT6mYurPzCY3KaD8JPxiAgGbH_AaoG2UxbABrN2sDCdIoOHQ1aY-4R-JvGzwxGWfDKZvU5VLSh5QlvPA
API_CONSUMER_HASH_KEY=ayvA_QOmIbTpO0KSEuWY_vfIAUOlVT2S

# Lokotro Pay SDK — set per build target.
# environment is one of: sandbox | staging | production
LOKOTRO_ENVIRONMENT=production

 

